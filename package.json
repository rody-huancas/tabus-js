{
  "name": "tabus",
  "version": "0.1.0",
  "description": "Type-safe cross-tab event bus with BroadcastChannel and in-memory fallback",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "keywords": [
    "broadcast-channel",
    "event-bus",
    "cross-tab",
    "typescript",
    "pubsub"
  ],
  "license": "MIT"
}
