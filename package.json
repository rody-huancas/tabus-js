{
  "name": "@rody-huancas/tabus",
  "version": "0.1.0",
  "description": "Type-safe cross-tab message bus using BroadcastChannel, with in-memory fallback.",
  "author": "Rody Huancas <rodyhuancas.04@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/rody-huancas/tabus#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rody-huancas/tabus.git"
  },
  "bugs": {
    "url": "https://github.com/rody-huancas/tabus/issues"
  },
  "keywords": [
    "broadcast",
    "tab",
    "cross-tab",
    "BroadcastChannel",
    "sync",
    "message-bus",
    "typescript"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm run lint && pnpm run test && pnpm run build"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false
}
